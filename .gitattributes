# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Go source files
*.go text eol=lf diff=go

# Go module files
go.mod text eol=lf
go.sum text eol=lf
go.work text eol=lf

# Configuration files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Makefile
Makefile text eol=lf
makefile text eol=lf
*.mk text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.o binary
*.bin binary
*.test binary

# Archives
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.7z binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# Logs
*.log text eol=lf

# Temporary files
tmp/** -text
*.tmp -text

# Ignore files
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
